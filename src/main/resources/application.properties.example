# Copy this file to application.properties for local development.
# Do not commit real secrets.

SPRING_APPLICATION_NAME=stock-dashboard
SERVER_PORT=8443

SSL_KEY_STORE=classpath:stock-dashboard.p12
SSL_KEY_STORE_PASSWORD=change-me
SSL_KEY_STORE_TYPE=PKCS12
SSL_KEY_ALIAS=stock-dashboard

DB_URL=jdbc:mysql://localhost:3306/stock_dashboard?serverTimezone=Asia/Seoul
DB_USERNAME=stock_user
DB_PASSWORD=change-me

SPRING_CACHE_TYPE=simple
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

DATA_API_SERVICE_KEY=change-me

KAKAO_CLIENT_ID=change-me
KAKAO_CLIENT_SECRET=change-me
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao

NAVER_CLIENT_ID=change-me
NAVER_CLIENT_SECRET=change-me
NAVER_NEWS_URL=https://openapi.naver.com/v1/search/news.json

GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=https://jyyouk.shop/oauth/google

PORTONE_API_KEY=change-me
PORTONE_API_SECRET=change-me
RESEND_API_KEY=change-me
RESEND_FROM_EMAIL=onboarding@resend.dev
APP_BASE_URL=http://localhost:5173
AES_SECRET_KEY=keep-existing-value-if-data-must-be-preserved

JWT_SECRET_ACCESS=change-me
JWT_SECRET_REFRESH=change-me

NOTIFY_COMPLETE_EMAIL=you@example.com

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-5.4-mini

AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_BUCKET=stock-dashboard-profile
AWS_REGION=ap-northeast-2

APP_LOG_LEVEL=INFO
